#!/bin/bash
# Lab 1 setup — runs on kubernetes-vm
# 1. Provisions Elastic Serverless (vector-optimized) via start_serverless.sh
# 2. Stores credentials as Instruqt agent variables for all challenges
# 3. Installs Python deps, clones repo, ingests corpus
# 4. Copies all 4 lab notebooks to /root/notebooks and starts Jupyter on :8888
#
# LLM synthesis (Lab 4) uses the Elastic Inference Service — ES_API_KEY authenticates both
# Elasticsearch queries and LLM calls. No separate Anthropic key required.
set -euo pipefail

echo "=== Provisioning Elastic Serverless (vector-optimized) ==="
/opt/workshops/start_serverless.sh \
  --project-type elasticsearch \
  --optimized-for vector

# Extract credentials from the provisioning output
ES_URL=$(jq -r '.["aws-us-east-1"].endpoints.elasticsearch' /tmp/project_results.json)
ES_APIKEY=$(jq -r '.["aws-us-east-1"].credentials.api_key' /tmp/project_results.json)
ES_KIBANA=$(jq -r '.["aws-us-east-1"].endpoints.kibana' /tmp/project_results.json)

# Store for all challenges via Instruqt agent variables
agent variable set ES_ENDPOINT "$ES_URL"
agent variable set ES_API_KEY "$ES_APIKEY"
agent variable set ES_KIBANA_URL "$ES_KIBANA"

export ES_ENDPOINT="$ES_URL"
export ES_API_KEY="$ES_APIKEY"

echo "ES:     $ES_URL"
echo "Kibana: $ES_KIBANA"
echo "Kibana also proxied at http://localhost:30001 (NGINX)"

echo "=== Installing Python dependencies ==="
pip install 'elasticsearch>=8.17,<9' jupyter requests
python3 -c "import elasticsearch; print('elasticsearch client:', elasticsearch.__version__)"

echo "=== Cloning workshop repo ==="
git clone --depth=1 https://github.com/jeffvestal/elastic-vectorsearch-workshop.git /root/workshop

echo "=== Ingesting corpus ==="
cd /root/workshop/corpus
python3 ingest.py 2>&1

echo "=== Setting up notebooks ==="
mkdir -p /root/notebooks
# Copy all 4 lab notebooks — Jupyter serves the whole /root/notebooks dir,
# so all appear in the browser without requiring separate Instruqt pages.
cp /root/workshop/instruqt/01-vector-search/lab1-vector-search.ipynb /root/notebooks/
cp /root/workshop/instruqt/02-where-vector-breaks/lab2-where-vector-breaks.ipynb /root/notebooks/
cp /root/workshop/instruqt/03-hybrid-search/lab3-hybrid-search.ipynb /root/notebooks/
cp /root/workshop/instruqt/04-why-it-matters/lab4-rag-pipeline.ipynb /root/notebooks/

echo "=== Starting Jupyter server on :8888 ==="
# Token and password auth disabled — sandbox is network-isolated.
nohup jupyter notebook \
  --ip=0.0.0.0 \
  --port=8888 \
  --no-browser \
  --allow-root \
  --NotebookApp.token='' \
  --NotebookApp.password='' \
  --NotebookApp.allow_origin='*' \
  --NotebookApp.disable_check_xsrf=True \
  --ServerApp.token='' \
  --ServerApp.password='' \
  --ServerApp.allow_origin='*' \
  --ServerApp.disable_check_xsrf=True \
  --notebook-dir=/root/notebooks \
  >> /var/log/jupyter.log 2>&1 &

echo "=== Health check ==="
# Wait for Jupyter to bind port 8888 (up to 15s)
for i in $(seq 1 15); do
  if curl -sf http://localhost:8888/api >/dev/null 2>&1; then
    echo "Jupyter ready after ${i}s"
    break
  fi
  sleep 1
done
if ! curl -sf http://localhost:8888/api >/dev/null 2>&1; then
  echo "WARNING: Jupyter did not start — check /var/log/jupyter.log"
  tail -20 /var/log/jupyter.log || true
fi
sleep 3
DOC_COUNT=$(python3 -c "
from elasticsearch import Elasticsearch
import os, sys
es = Elasticsearch(os.environ['ES_ENDPOINT'], api_key=os.environ['ES_API_KEY'])
print(es.count(index='aiewf-workshop-docs')['count'])
")
if [ "$DOC_COUNT" -eq 0 ]; then
    echo "ERROR: 0 documents in index — ingest failed. Check output above."
    exit 1
fi
echo "Index: $DOC_COUNT documents OK"

echo "=== Setup complete ==="
echo "Kibana: http://kubernetes-vm:30001"
echo "Jupyter: http://kubernetes-vm:8888 (no auth)"
